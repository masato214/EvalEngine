# ============================================================
# EvalEngine - Environment Variables
# Copy to .env and fill in values
# ============================================================

# Database
DATABASE_URL=postgresql://eval:eval@localhost:5432/evalengine

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-32-chars-minimum-secret
JWT_REFRESH_SECRET=change-me-32-chars-refresh-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Internal service communication (NestJS → FastAPI)
AI_SERVICE_URL=http://localhost:8000
AI_INTERNAL_KEY=change-me-internal-key-16-chars

# OpenAI
OPENAI_API_KEY=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
EMBEDDING_MODEL=text-embedding-3-small

# Next.js Admin Panel
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Ports
API_PORT=3001
AI_PORT=8000
WEB_PORT=3000
